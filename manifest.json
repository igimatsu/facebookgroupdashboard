{
  "manifest_version": 3,
  "name": "FB Group Manager",
  "version": "0.1.0",
  "description": "Tracker & semi-automated posting assistant untuk grup jual-beli Facebook milik sendiri.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://*.facebook.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "FB Group Manager"
  },
  "side_panel": {
    "default_path": "src/sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.facebook.com/groups/joins*"],
      "js": ["src/content/detect-groups.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.facebook.com/groups/*"],
      "js": ["src/content/composer-assist.js", "src/content/engagement-reader.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.facebook.com/marketplace/*"],
      "js": ["src/content/marketplace-assist.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
